modules = ["nodejs-24", "python3", "python-3.11"]

[[artifacts]]
id = "artifacts/ai-dashboard"

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "gce"
build = ["pnpm", "run", "build:production"]
run = ["pnpm", "start"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "python-lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "format-check"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "python-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/ai-dashboard: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "python-lint"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv tool run ruff check artifacts/ai-training-server/ --output-format=concise"

[[workflows.workflow]]
name = "format-check"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm exec prettier --check \"artifacts/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\""

[[workflows.workflow]]
name = "python-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv tool run mypy artifacts/ai-training-server/ --ignore-missing-imports --no-strict-optional --follow-imports=skip"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 MODEL_API_PORT=9878 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/ai-dashboard: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/ai-dashboard run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 MODEL_API_PORT=9878 pnpm --filter @workspace/api-server run dev & PORT=5000 BASE_PATH=/ API_PORT=8080 pnpm --filter @workspace/ai-dashboard run dev"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["ffmpeg-full", "freetype", "glibcLocales", "lcms2", "libimagequant", "libjpeg", "libsndfile", "libtiff", "libwebp", "libxcrypt", "openjpeg", "pkg-config", "tcl", "tk", "xsimd", "zlib"]

